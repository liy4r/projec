# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI="a"
# Local example:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/academy_db?schema=public"

# # ─── JWT ──────────────────────────────────────────────────────────────────────
# JWT_SECRET="change-this-to-a-random-32-char-string-in-production"
# JWT_EXPIRES_IN=7d             # e.g. 15m | 1h | 7d

# # ─── CORS ─────────────────────────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:5173   # frontend URL, use * for public